```gitignore
# Build artifacts
*.dll
*.exe
*.pdb
*.so
*.dylib
*.obj
*.o
*.a
*.lib
*.out

# Dependencies
packages/
lib/
node_modules/
bower_components/

# Logs
*.log
*.tmp

# User-specific files
.vs/
.idea/
*.userprefs
*.suo
*.user
*.aps
*.ncb
*.ilk
*.idb
*.pidb
*.meta
*.cache
*.dbmdl

# Environment specific
.env
.env.local
.env.*
!env.example
!env.sample

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
Icon?
```